# 인증서버(OAuth 2.1) 외부 URL — 브라우저가 접근하는 주소(= auth-server ISSUER)
VITE_AUTH_BASE=http://localhost:9000
# multi_modal_agent API 베이스 URL
VITE_MMA_BASE=http://localhost:8000
# public 클라이언트 ID (auth-server 시드: frontend-spa)
VITE_OAUTH_CLIENT_ID=frontend-spa
# 요청 스코프 (api 스코프가 multi_modal_agent 보호 라우터 요구사항)
VITE_OAUTH_SCOPE=openid profile api
